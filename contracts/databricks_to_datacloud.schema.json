{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pulse360/contracts/databricks_to_datacloud",
  "title": "Databricks to Data Cloud Handoff",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entity_id",
    "source_account_id",
    "duplicate_confidence",
    "hierarchy_parent_id",
    "hierarchy_child_id",
    "validity_score",
    "review_flag",
    "unified_profile_id",
    "identity_confidence",
    "hierarchy_payload",
    "intent_signal_payload",
    "group_revenue_rollup",
    "cross_sell_propensity",
    "health_score",
    "coverage_gap_flag",
    "competitor_risk_signal",
    "primary_brand_name",
    "active_product_count",
    "engagement_intensity_score",
    "open_opportunity_count",
    "last_engagement_timestamp",
    "last_synced_timestamp",
    "external_legal_name",
    "is_externally_validated",
    "validity_score_external",
    "ai_narrative",
    "ai_recommended_actions",
    "ai_narrative_generated_at",
    "enrichment_run_id",
    "regulatory_readiness_score",
    "duplicate_exposure_count",
    "group_known_subsidiary_count",
    "crm_covered_subsidiary_count",
    "group_revenue_visible",
    "external_revenue_confirmed",
    "model_id",
    "prompt_version",
    "source_refs",
    "citation_count",
    "run_id",
    "run_timestamp",
    "model_version"
  ],
  "properties": {
    "entity_id": { "type": "string", "minLength": 1 },
    "source_account_id": { "type": "string", "minLength": 1 },
    "duplicate_confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "hierarchy_parent_id": { "type": "string" },
    "hierarchy_child_id": { "type": "string" },
    "validity_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "review_flag": { "type": "boolean" },
    "unified_profile_id": { "type": "string", "minLength": 1 },
    "identity_confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "hierarchy_payload": { "type": "string", "minLength": 1 },
    "intent_signal_payload": { "type": "string", "minLength": 1 },
    "group_revenue_rollup": { "type": "number", "minimum": 0 },
    "cross_sell_propensity": { "type": "number", "minimum": 0, "maximum": 100 },
    "health_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "coverage_gap_flag": { "type": "boolean" },
    "competitor_risk_signal": { "type": "number", "minimum": 0, "maximum": 100 },
    "primary_brand_name": { "type": "string", "minLength": 1 },
    "active_product_count": { "type": "integer", "minimum": 0 },
    "engagement_intensity_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "open_opportunity_count": { "type": "integer", "minimum": 0 },
    "last_engagement_timestamp": { "type": "string", "format": "date-time" },
    "last_synced_timestamp": { "type": "string", "format": "date-time" },
    "external_legal_name": { "type": "string", "minLength": 1 },
    "external_registration_number": { "type": "string" },
    "is_externally_validated": { "type": "boolean" },
    "validity_score_external": { "type": "number", "minimum": 0, "maximum": 100 },
    "external_subsidiaries_found": { "type": "integer", "minimum": 0 },
    "ai_narrative": { "type": "string", "minLength": 1 },
    "ai_recommended_actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rank",
          "action_type",
          "target",
          "reasoning",
          "estimated_revenue_impact",
          "confidence",
          "source_ids"
        ],
        "properties": {
          "rank": { "type": "integer", "minimum": 1 },
          "action_type": { "type": "string", "minLength": 1 },
          "target": { "type": "string", "minLength": 1 },
          "target_record_id": { "type": "string" },
          "reasoning": { "type": "string", "minLength": 1 },
          "estimated_revenue_impact": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_ids": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "ai_narrative_generated_at": { "type": "string", "format": "date-time" },
    "enrichment_run_id": { "type": "string", "minLength": 1 },
    "regulatory_readiness_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "duplicate_exposure_count": { "type": "integer", "minimum": 0 },
    "group_known_subsidiary_count": { "type": "integer", "minimum": 0 },
    "crm_covered_subsidiary_count": { "type": "integer", "minimum": 0 },
    "group_revenue_visible": { "type": "number", "minimum": 0 },
    "external_revenue_confirmed": { "type": "number", "minimum": 0 },
    "model_id": { "type": "string", "minLength": 1 },
    "prompt_version": { "type": "string", "minLength": 1 },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "source_id",
          "source_name",
          "source_type",
          "source_url",
          "document_date",
          "accessed_at",
          "excerpt",
          "jurisdiction"
        ],
        "properties": {
          "source_id": { "type": "string", "minLength": 1 },
          "source_name": { "type": "string", "minLength": 1 },
          "source_type": { "type": "string", "minLength": 1 },
          "source_url": { "type": "string", "format": "uri" },
          "document_date": { "type": "string", "format": "date" },
          "accessed_at": { "type": "string", "format": "date-time" },
          "excerpt": { "type": "string", "minLength": 1 },
          "jurisdiction": { "type": "string", "minLength": 1 }
        }
      }
    },
    "citation_count": { "type": "integer", "minimum": 0 },
    "run_id": { "type": "string", "minLength": 1 },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "model_version": { "type": "string", "minLength": 1 }
  }
}
