{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pulse360/contracts/datacloud_account_core_canonical_v2",
  "title": "Data Cloud Canonical Account Core Export v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "canonical_account_id",
    "ssot_id",
    "source_account_id",
    "deterministic_key",
    "account_name",
    "parent_account_id",
    "industry",
    "country_code",
    "identity_confidence",
    "validity_score",
    "run_id",
    "run_timestamp",
    "model_version"
  ],
  "properties": {
    "canonical_account_id": { "type": "string", "minLength": 1 },
    "ssot_id": { "type": "string", "minLength": 1 },
    "source_account_id": { "type": "string", "minLength": 1 },
    "deterministic_key": { "type": "string", "minLength": 1 },
    "account_name": { "type": "string", "minLength": 1 },
    "parent_account_id": { "type": "string" },
    "industry": { "type": "string", "minLength": 1 },
    "country_code": { "type": "string", "minLength": 2, "maxLength": 2 },
    "identity_confidence": { "type": "number", "minimum": 0, "maximum": 100 },
    "validity_score": { "type": "number", "minimum": 0, "maximum": 100 },
    "run_id": { "type": "string", "minLength": 1 },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "model_version": { "type": "string", "minLength": 1 }
  }
}
