{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pulse360/contracts/salesforce_account360_hierarchy_lwc",
  "title": "Salesforce Account 360 Hierarchy LWC Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "unified_profile_id",
    "source_account_id",
    "account_name",
    "hierarchy_payload",
    "group_revenue_rollup",
    "cross_sell_propensity",
    "coverage_gap_flag",
    "last_synced_timestamp",
    "data_health_status",
    "degraded_mode_message",
    "run_id",
    "run_timestamp",
    "model_version"
  ],
  "properties": {
    "unified_profile_id": { "type": "string", "minLength": 1 },
    "source_account_id": { "type": "string", "minLength": 1 },
    "account_name": { "type": "string", "minLength": 1 },
    "hierarchy_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["group_id", "children"],
      "properties": {
        "group_id": { "type": "string", "minLength": 1 },
        "children": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["entity_id", "name"],
            "properties": {
              "entity_id": { "type": "string", "minLength": 1 },
              "name": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "group_revenue_rollup": { "type": "number", "minimum": 0 },
    "cross_sell_propensity": { "type": "number", "minimum": 0, "maximum": 100 },
    "coverage_gap_flag": { "type": "boolean" },
    "last_synced_timestamp": { "type": "string", "format": "date-time" },
    "data_health_status": {
      "type": "string",
      "enum": ["healthy", "degraded"]
    },
    "degraded_mode_message": { "type": "string" },
    "run_id": { "type": "string", "minLength": 1 },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "model_version": { "type": "string", "minLength": 1 }
  }
}
