{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "pulse360/contracts/databricks_hierarchy_graph",
  "title": "Databricks Hierarchy Graph Output",
  "type": "object",
  "additionalProperties": false,
  "required": ["run_id", "run_timestamp", "model_version", "entities", "edges"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "run_timestamp": { "type": "string", "format": "date-time" },
    "model_version": { "type": "string", "minLength": 1 },
    "entities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["entity_id", "legal_name", "deterministic_key", "validity_score"],
        "properties": {
          "entity_id": { "type": "string", "pattern": "^ent_[A-Za-z0-9_]+$" },
          "legal_name": { "type": "string", "minLength": 1 },
          "deterministic_key": { "type": "string", "minLength": 1 },
          "validity_score": { "type": "number", "minimum": 0, "maximum": 100 }
        }
      }
    },
    "edges": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["parent_entity_id", "child_entity_id", "relationship_type"],
        "properties": {
          "parent_entity_id": { "type": "string", "pattern": "^ent_[A-Za-z0-9_]+$" },
          "child_entity_id": { "type": "string", "pattern": "^ent_[A-Za-z0-9_]+$" },
          "relationship_type": { "type": "string", "enum": ["SUBSIDIARY_OF", "BRANCH_OF", "DIVISION_OF"] }
        }
      }
    }
  }
}
