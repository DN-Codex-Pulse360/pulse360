<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Require_Merged_Account_On_Approval</fullName>
    <active>true</active>
    <description>Requires the steward to select the losing account before approving a merge case.</description>
    <errorConditionFormula>
        OR(
            ISPICKVAL(Decision_Status__c, "Approved"),
            ISPICKVAL(Status__c, "Approved")
        )
        &amp;&amp;
        ISBLANK(Merged_Account__c)
    </errorConditionFormula>
    <errorDisplayField>Merged_Account__c</errorDisplayField>
    <errorMessage>Select the merged account before approving this governance case.</errorMessage>
</ValidationRule>
